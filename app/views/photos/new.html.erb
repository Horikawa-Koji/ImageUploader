<h1>写真アップロード</h1>

<% if @photo.errors.any? %>
  <div class="alert alert-danger">
    <ul>
      <% @photo.errors.full_messages.each do |message| %>
        <li style="color: red;"><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: @photo do |form| %>
  <div>
    タイトル<%= form.text_field :title %>
  </div>

  <div>
    画像ファイル<%= form.file_field :featured_image, accept: "image/*" %>
  </div>

  <div>
    <%= form.submit %>
  </div>
  <%= link_to "キャンセル", photos_path %>
<% end %>
