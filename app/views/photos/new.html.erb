<h1 class="header-title">写真アップロード</h1>

<% if @photo.errors.any? %>
  <div class="alert alert-danger">
    <ul>
      <% @photo.errors.full_messages.each do |message| %>
      <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: @photo, local: true do |form| %>
  <div class="form-group">
    <%= form.label :title, "タイトル" %>
    <%= form.text_field :title %>
  </div>

  <div class="form-group">
    <%= form.label :featured_image, "画像ファイル" %>
    <%= form.file_field :featured_image, accept: "image/*" %>
  </div>

  <div>
    <%= form.submit "写真をアップロードする" %>
  </div>
  <%= link_to "キャンセル", photos_path %>
<% end %>
