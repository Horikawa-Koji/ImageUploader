<h1 class="header-title">ログイン</h1>

<%= simple_format(flash[:alert], class: "flash-alert") if flash[:alert] %>

<%= form_with url: session_path, local: true, class: "login-form" do |form| %>
  <div class="form-group">
    <%= form.label :email_address, "ユーザーID" %>
    <%= form.email_field :email_address, autofocus: true, autocomplete: "username", placeholder: "userID" %>
  </div>

  <div class="form-group">
    <%= form.label :password, "パスワード" %>
    <%= form.password_field :password, autocomplete: "current-password", placeholder: "password" %>
  </div>

  <%= form.submit "ログインする" %>
<% end %>
